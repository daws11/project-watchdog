# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_watchdog

# Backend
PORT=3001
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3001

# AI / LLM
# Choose provider: "moonshot" (Kimi) or "openai"
LLM_PROVIDER=openai

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENAI_ADVANCED_MODEL=gpt-4.1

# Moonshot / Kimi (required when LLM_PROVIDER=moonshot)
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_DEFAULT_MODEL=moonshot-v1-32k
MOONSHOT_ADVANCED_MODEL=moonshot-v1-128k

# WhatsApp Web Integration (whatsapp-web.js)
#
# The system uses whatsapp-web.js as the sole WhatsApp integration,
# handling both inbound message ingestion and outbound daily reports.
#
# Architecture:
# - wa-ingestor (whatsapp-web.js) connects to WhatsApp Web via Puppeteer
# - Uses LocalAuth for session persistence (WA_SESSION_DIR)
# - First run: Scan QR code to authenticate
# - Subsequent runs: Auto-login from persisted session
#
# Outbound messages (reports) use a durable outbox pattern:
# - Commands are queued in wa_ingestor_commands table
# - wa-ingestor polls for commands and executes them
# - Failed sends are retried with exponential backoff (1s, 2s, 4s, 8s, 16s)
# - Max 5 attempts before giving up

# Internal auth token (sent as `X-Ingest-Token` header)
WHATSAPP_INGEST_TOKEN=your_internal_ingest_token_here

# Backend endpoint for the ingestor to communicate with
BACKEND_INGEST_URL=http://127.0.0.1:3001/ingest/whatsapp-web

# Session persistence directory (WhatsApp Web session is stored here)
WA_SESSION_DIR=.wa-session

# Headless browser mode (set to false for local development to see QR code)
WA_HEADLESS=true

# Optional: Specify Chrome/Chromium executable path (useful if Puppeteer download is disabled)
# WA_PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# Command polling interval in milliseconds (how often wa-ingestor checks for new commands)
WA_COMMAND_POLL_MS=3000

# Status heartbeat interval in milliseconds (how often wa-ingestor reports its status)
WA_STATUS_HEARTBEAT_MS=10000

# Authentication
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_32_plus_char_encryption_key_here

# Initial admin seeding (used by `pnpm db:seed`)
SEED_ADMIN_NAME="Watchdog Admin"
SEED_ADMIN_EMAIL=admin@watchdog.local
SEED_ADMIN_PASSWORD=change_me_before_seeding
